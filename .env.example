# Firebase web config for the bb-daily-ops-report project.
# Copy this file to .env.local and fill in the values (Firebase console > Project settings).
# These are client-public values; security is enforced by Firestore rules, not by hiding them.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
